# Copy to /etc/default/ssh-stats on Debian/Ubuntu or /etc/sysconfig/ssh-stats
# on RHEL-family systems, then edit to match your host.

SSH_STATS_LISTEN_ADDRESS=127.0.0.1
SSH_STATS_PORT=9122
SSH_STATS_LOG_DIR=/var/log
SSH_STATS_LOG_FILE=auth.log
SSH_STATS_LOG_LEVEL=INFO
SSH_STATS_POLL_INTERVAL=1.0
SSH_STATS_REFRESH_INTERVAL=30.0
SSH_STATS_MAX_HISTORY=5000

# Safer default for internet-facing hosts. Set SSH_STATS_METRICS_LABEL_MODE=full
# only if you explicitly want per-user and per-source metric labels without caps.
SSH_STATS_METRICS_LABEL_MODE=bounded
SSH_STATS_METRICS_MAX_USERS=200
SSH_STATS_METRICS_MAX_SOURCE_IPS=500
SSH_STATS_METRICS_MAX_AUTH_METHODS=32

# Leave blank to keep the JSON API enabled. Set to true to expose only /metrics
# and /health.
SSH_STATS_DISABLE_JSON_API=

# Comma-separated browser origins allowed to read JSON API responses. Leave
# blank for no CORS headers, which is the safest default.
SSH_STATS_CORS_ALLOW_ORIGINS=
